{
  "name": "codeforge-ai-editor",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n RENDERER,ELECTRON -c green,cyan \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@vscode/codicons": "^0.0.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.3.2",
    "vite": "^5.4.19",
    "wait-on": "^8.0.5"
  }
}
